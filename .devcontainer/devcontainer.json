{
  "name": "Adaptive Traffic Signal — Green Corridor",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // Give the container enough memory for YOLO inference
  "hostRequirements": {
    "memory": "8gb"
  },

  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/workspace/adaptive-traffic-signal-green-corridor/.venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "ms-python.python"
        },
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "charliermarsh.ruff",
        "eamodio.gitlens",
        "qwtel.sqlite-viewer",
        "tamasfe.even-better-toml",
        "ms-azuretools.vscode-docker",
        "ms-toolsai.jupyter"
      ]
    }
  },

  // Ports used by the project
  "forwardPorts": [
    5000, // Flask dashboard (Week 4)
    8000  // alternative HTTP server
  ],
  "portsAttributes": {
    "5000": { "label": "Dashboard (Flask)", "onAutoForward": "notify" },
    "8000": { "label": "HTTP server",       "onAutoForward": "silent" }
  },

  // Sync to catch any changes made after the image was built (fast no-op when image is fresh)
  "postCreateCommand": "uv sync --frozen",

  // Keep the venv directory inside the workspace so VS Code can find it
  "remoteEnv": {
    "UV_PROJECT_ENVIRONMENT": "/workspace/adaptive-traffic-signal-green-corridor/.venv"
  },

  "remoteUser": "root"
}
